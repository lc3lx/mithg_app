# Copy to .env and fill values. Use KEY=value (not KEY:value).
NODE_ENV=development

DB_URI=mongodb://127.0.0.1:27017/your_db
CLIENT_URL=http://localhost:3000
BASE_URL=http://localhost:8000

JWT_SECRET_KEY=change-me
JWT_EXPIRE_TIME=7d

# Optional: one-time default admin bootstrap (keep false in production)
ALLOW_DEFAULT_ADMIN_BOOTSTRAP=false
ADMIN_BOOTSTRAP_SECRET=
DEFAULT_ADMIN_INITIAL_PASSWORD=
